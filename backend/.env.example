# Copia este archivo a backend/.env y completa los valores reales.
PORT=3000
NODE_ENV=development

# Base de datos
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/sigi?appName=Cluster0

# Seguridad
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=1d

# Frontend permitido para CORS (en prod, poner el dominio real)
CLIENT_ORIGIN=*

# Correo (verificación de cuenta y recuperación de contraseña)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Reglas de negocio
ESCALATION_HOURS=48
RESET_TOKEN_MINUTES=30
